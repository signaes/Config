nllama_serve() {
  MODEL="Qwen2.5-Coder-1.5B-Q8_0-GGUF"

  llama-server \
    -hf ggml-org/$MODEL \
    --port 8012 \
    -ngl 99 \
    -fa \
    -ub 1024 \
    -b 1024 \
    -dt 0.1 \
    --ctx-size 0 \
    --cache-reuse 256
}

current_git_branch() {
  { git rev-parse --is-inside-work-tree &> /dev/null && echo "$(git branch --show-current)" } || {}
}

pdf2png() {
  for f in *.pdf(N); do
    pdftoppm -png -r 300 "$f" "${f%.pdf}"
  done
}

my_ip() {
  ipconfig getifaddr en0 || ipconfig getifaddr en1
}
