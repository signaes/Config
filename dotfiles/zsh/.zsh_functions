current_git_branch() {
  { git rev-parse --is-inside-work-tree &> /dev/null && echo "$(git branch --show-current)" } || {}
}

pdf2png() {
  for f in *.pdf(N); do
    pdftoppm -png -r 300 "$f" "${f%.pdf}"
  done
}

my_ip() {
  ipconfig getifaddr en0 || ipconfig getifaddr en1
}

